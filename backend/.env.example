# Sao chép file này thành .env và điền thông tin thật
PORT=4000

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=crm_user
DB_PASSWORD=your_password_here
DB_NAME=video_ai_crm

# JWT - đổi thành chuỗi ngẫu nhiên dài, bí mật
JWT_SECRET=doi-chuoi-nay-thanh-chuoi-ngau-nhien-rat-dai
JWT_EXPIRES=7d

# Domain frontend được phép gọi API (cách nhau bởi dấu phẩy)
CORS_ORIGINS=http://localhost:5173,https://crm.tencongty.vn

# Lưu trữ file tài nguyên dự án (ảnh/video)
UPLOAD_DIR=uploads
STORAGE_QUOTA_GB=5
